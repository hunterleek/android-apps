<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="DialButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:backgroundTint">@color/grey_medium</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="cornerRadius">32dp</item>
    </style>

    <style name="CallButton">
        <item name="android:layout_width">64dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">12dp</item>
        <item name="android:background">@drawable/circle_button</item>
        <item name="android:padding">16dp</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:backgroundTint">@color/grey_medium</item>
        <item name="tint">@color/white</item>
    </style>
</resources>
